formulas:
  未命名: ""
views:
  - type: table
    name: 视图
    filters:
      and:
        - file.ext == "md"
    groupBy:
      property: file.folder
      direction: ASC
    order:
      - file.name
      - tags
      - file.ctime
      - file.mtime
    sort:
      - property: tags
        direction: DESC
      - property: file.name
        direction: ASC
    columnSize:
      file.name: 1306
      note.tags: 323
