formulas:
  未命名: ""
views:
  - type: table
    name: 视图
    filters:
      and:
        - file.ext == "md"
        - file.folder == "笔记"
    order:
      - file.name
      - tags
      - file.ctime
      - file.mtime
    sort:
      - property: file.ctime
        direction: DESC
      - property: file.name
        direction: ASC
    columnSize:
      file.name: 1113
      note.tags: 323
    cardSize: 430
    imageFit: contain
    imageAspectRatio: 1
