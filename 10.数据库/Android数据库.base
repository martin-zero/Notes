filters:
  and:
    - file.tags.contains("Android系统")
    - '!file.tags.contains("MOC")'
views:
  - type: table
    name: 表格
    order:
      - file.name
      - file.tags
    sort:
      - property: file.name
        direction: DESC
      - property: file.tags
        direction: DESC
  - type: list
    name: 视图
