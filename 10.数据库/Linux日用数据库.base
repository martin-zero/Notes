filters:
  and:
    - file.tags.contains("Linux日用")
    - '!file.tags.contains("MOC")'
views:
  - type: table
    name: 按标签浏览
    order:
      - file.name
      - file.ctime
      - file.tags
    sort:
      - property: file.name
        direction: ASC
    columns:
      - file.name
      - file.tags
    columnSize:
      file.name: 336
  - type: list
    name: 按名称浏览
    sort:
      - property: file.name
        direction: ASC
